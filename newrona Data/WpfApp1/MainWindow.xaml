<Window x:Class="NewronaData.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:NewronaData.Views"
        Title="뉴로나 내전 기록기" Height="640" Width="1000"
        FontFamily="Malgun Gothic" FontSize="13">
    <TabControl Margin="6">
        <TabItem Header="내전러">
            <views:PlayerView DataContext="{Binding Players}" />
        </TabItem>
        <TabItem Header="경기 기록">
            <views:MatchView DataContext="{Binding Matches}" />
        </TabItem>
        <TabItem Header="서버 등급">
            <views:RankView DataContext="{Binding Ranks}" />
        </TabItem>
    </TabControl>
</Window>
