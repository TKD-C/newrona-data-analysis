<UserControl x:Class="NewronaData.Views.PlayerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="260" />
        </Grid.ColumnDefinitions>

        <!-- 내전러 목록 -->
        <DataGrid Grid.Column="0" Margin="0,0,8,0"
                  ItemsSource="{Binding Players}"
                  SelectedItem="{Binding SelectedPlayer}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="이름" Binding="{Binding Name}" Width="*" />
                <DataGridTextColumn Header="롤 닉네임" Binding="{Binding LolNickname}" Width="*" />
                <DataGridTextColumn Header="주 라인" Binding="{Binding MainLanesText}" Width="*" />
                <DataGridTextColumn Header="부 라인" Binding="{Binding SubLanesText}" Width="*" />
                <DataGridTextColumn Header="점수" Binding="{Binding Score}" Width="60" />
                <DataGridTextColumn Header="승" Binding="{Binding Wins}" Width="45" />
                <DataGridTextColumn Header="패" Binding="{Binding Losses}" Width="45" />
                <DataGridTextColumn Header="승률" Binding="{Binding WinRate, StringFormat=P0}" Width="60" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- 입력 폼 -->
        <StackPanel Grid.Column="1">
            <TextBlock Text="내전러 정보" FontWeight="Bold" Margin="0,0,0,6" />
            <TextBlock Text="이름 *" />
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
            <TextBlock Text="롤 닉네임" />
            <TextBox Text="{Binding Nickname, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,6" />
            <TextBlock Text="점수" />
            <TextBox Text="{Binding Score, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,2" />
            <TextBlock Margin="0,0,0,10" Foreground="DarkSlateBlue">
                <Run Text="예상 등급: " />
                <Run Text="{Binding RankPreview, Mode=OneWay}" FontWeight="Bold" />
            </TextBlock>

            <UniformGrid Columns="2">
                <Button Content="추가" Command="{Binding AddCommand}" Margin="0,0,3,3" Padding="0,6" />
                <Button Content="수정" Command="{Binding UpdateCommand}" Margin="3,0,0,3" Padding="0,6" />
                <Button Content="삭제" Command="{Binding DeleteCommand}" Margin="0,3,3,0" Padding="0,6" />
                <Button Content="새로 입력" Command="{Binding NewCommand}" Margin="3,3,0,0" Padding="0,6" />
            </UniformGrid>
        </StackPanel>
    </Grid>
</UserControl>
