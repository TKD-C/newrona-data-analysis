<UserControl x:Class="NewronaData.Views.MatchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 입력 영역 -->
        <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="1" Padding="8" Margin="0,0,0,8">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                        <TextBlock Text="1팀" FontWeight="Bold" Margin="0,0,0,4" />
                        <ItemsControl ItemsSource="{Binding Team1}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ComboBox Margin="0,0,0,3" ItemsSource="{Binding Available}"
                                              SelectedItem="{Binding Selected}" DisplayMemberPath="Name" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                        <TextBlock Text="2팀" FontWeight="Bold" Margin="0,0,0,4" />
                        <ItemsControl ItemsSource="{Binding Team2}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ComboBox Margin="0,0,0,3" ItemsSource="{Binding Available}"
                                              SelectedItem="{Binding Selected}" DisplayMemberPath="Name" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <TextBlock Text="승리 팀:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <RadioButton Content="1팀" IsChecked="{Binding Team1Wins}" VerticalAlignment="Center" Margin="0,0,10,0" />
                    <RadioButton Content="2팀" VerticalAlignment="Center" Margin="0,0,20,0" />
                    <TextBlock Text="비고:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox Width="240" Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                    <Button Content="경기 저장" Command="{Binding SaveCommand}" Padding="14,4" Margin="14,0,0,0" />
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 기록 목록 -->
        <DockPanel Grid.Row="1">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="경기 기록" FontWeight="Bold" VerticalAlignment="Center" />
                <Button Content="선택 삭제" Command="{Binding DeleteCommand}" Padding="10,2" Margin="10,0,0,0" />
            </StackPanel>
            <ListBox ItemsSource="{Binding Matches}" SelectedItem="{Binding SelectedMatch}"
                     DisplayMemberPath="Summary" HorizontalContentAlignment="Stretch" />
        </DockPanel>
    </Grid>
</UserControl>
