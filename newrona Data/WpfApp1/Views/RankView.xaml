<UserControl x:Class="NewronaData.Views.RankView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel Margin="8">
        <Button DockPanel.Dock="Top" Content="새로고침" Command="{Binding RefreshCommand}"
                HorizontalAlignment="Left" Padding="14,4" Margin="0,0,0,8" />
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Rank.Name}" FontWeight="Bold"
                                       FontSize="15" Foreground="DarkSlateBlue" VerticalAlignment="Top" />
                            <TextBlock Grid.Column="1" TextWrapping="Wrap" VerticalAlignment="Top">
                                <Run Text="= " />
                                <Run Text="{Binding PlayersText, Mode=OneWay}" />
                            </TextBlock>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
